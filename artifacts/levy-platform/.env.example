# Levy Platform (Frontend) Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Node environment
NODE_ENV=development

# Server port (Used by development server, Required)
# The port that Vite dev server will run on
PORT=3000

# Base path for the application (Required)
# Used by Vite for the base href in index.html
# Use "/" for root, or a path like "/app/" for subdirectory deployment
BASE_PATH=/

# API Server configuration (Client-side, exposed to browser)
# Must use VITE_ prefix to be accessible via import.meta.env in the frontend
# Point this to your API server URL
VITE_API_URL=http://localhost:8080
