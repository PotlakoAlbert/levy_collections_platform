# API Server Environment Configuration
# Copy to repo root .env (loaded by run-with-env.mjs) or artifacts/api-server/.env

# Database (Required)
DATABASE_URL=postgresql://user:password@host:5432/levy_db?sslmode=require

# Server
PORT=8080
NODE_ENV=development

# Auth
SESSION_SECRET=your-super-secret-key-change-in-production

# Redis — required for BullMQ workers; falls back to inline processing if unavailable
REDIS_URL=redis://localhost:6379

# AI — use "mock" for local dev without API credits
AI_PROVIDER=mock
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Logging
LOG_LEVEL=info

# WhatsApp — use "mock" for local dev; workers still run (only API calls are mocked)
# SKIP_WORKERS=true forces inline job processing without Redis
WHATSAPP_MODE=mock
SKIP_WORKERS=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_URL=https://graph.facebook.com
