# Root Workspace Environment Configuration Example
# This file is shared across the workspace

# Database connection (Required for API Server and migrations)
DATABASE_URL=postgresql://user:password@localhost:5432/levy_db?sslmode=require

# Server port (Used by API Server)
PORT=8080

# Authentication & Security
SESSION_SECRET=your-super-secret-key-here-change-in-production

# AI Provider configuration
AI_PROVIDER=mock
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Redis connection (Optional)
REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development
